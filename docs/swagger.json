    "definitions": {
        "v1.ChangePasswordRequest": {
            "type": "object",
            "required": [
                "newPassword",
                "oldPassword"
            ],
            "properties": {
                "newPassword": {
                    "type": "string",
                    "maxLength": 72,
                    "minLength": 12,
                    "example": "1234567890123"
                },
                "oldPassword": {
                    "type": "string",
                    "example": "123456789012"
                }
            }
        },
        "v1.ContentItemDetailResponseData": {
            "type": "object",
