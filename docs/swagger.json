    "host": "localhost:8000",
    "paths": {
        "/content-items": {
            "get": {
                "security": [
                    {
                        "Bearer": []
                    }
                ],
                "description": "统一内容列表查询入口，支持内容类型、处理状态、内容标记和订阅源单值 AND 过滤",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "内容条目模块"
                ],
                "summary": "查询统一内容条目列表",
                "parameters": [
                    {
                        "type": "string",
                        "description": "content type: text/audio",
                        "name": "content_type",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "processing status: unprocessed/completed",
                        "name": "processing_status",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "content mark: later/favorite",
                        "name": "mark",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "feed id",
                        "name": "feed_id",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "page",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "page size",
                        "name": "pageSize",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/v1.ListContentItemsResponse"
                        }
                    }
                }
            }
        },
