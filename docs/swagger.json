                "availableText": {
                    "type": "string"
                },
                "contentSafe": {
                    "type": "string"
                },
                "contentType": {
                    "type": "string",
                    "example": "text"
                },
                "descriptionSafe": {
                    "type": "string"
                },
                "favorited": {
                    "type": "boolean"
                },
                "feedId": {
