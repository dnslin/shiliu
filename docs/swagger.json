                },
                "fetchedAt": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "markedLater": {
                    "type": "boolean"
                },
                "processingStatus": {
                    "type": "string",
                    "example": "unprocessed"
                },
                "publishedAt": {
                    "type": "string"
                },
                "showNotesSafe": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                }
            }
        },
